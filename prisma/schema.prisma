generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          String  @id @default(uuid())
  nom         String  @unique
  description String?

  utilisateurs Utilisateur[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Utilisateur {
  id        String  @id @default(uuid())
  nom       String
  prenom    String
  email     String  @unique
  telephone String?
  login     String  @unique
  password  String
  statut    Boolean @default(true)

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  demandes Demande[]

  historiqueStatuts HistoriqueStatutDemande[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum StatutDemande {
  EN_ATTENTE
  EN_COURS
  VALIDEE
  REJETEE
}

model Demande {
  id     String @id @default(uuid())
  numero String @unique

  nomDemandeur    String
  prenomDemandeur String
  cin             String
  telephone       String
  email           String?

  referenceFonciere String
  adresseBien       String

  statut       StatutDemande @default(EN_ATTENTE)
  observations String?
  motifRejet   String?

  utilisateurId String
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id])

  historiqueStatuts HistoriqueStatutDemande[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cin, referenceFonciere])
}

model HistoriqueStatutDemande {
  id            String        @id @default(uuid())
  ancienStatut  StatutDemande
  nouveauStatut StatutDemande
  motif         String?

  demandeId String
  demande   Demande @relation(fields: [demandeId], references: [id], onDelete: Cascade)

  utilisateurId String
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id])
  createdAt     DateTime    @default(now())

  @@index([demandeId])
  @@index([utilisateurId])
}
