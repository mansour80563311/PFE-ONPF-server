generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          String  @id @default(uuid())
  nom         String  @unique
  description String?

  utilisateurs Utilisateur[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Utilisateur {
  id        String  @id @default(uuid())
  nom       String
  prenom    String
  email     String  @unique
  telephone String?
  login     String  @unique
  password  String
  statut    Boolean @default(true)

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  demandes Demande[]

  historiqueStatuts   HistoriqueStatutDemande[]
  documentsTeleverses DemandeDocument[]
  journauxCloture     JournalCloture[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum StatutDemande {
  EN_ATTENTE
  EN_COURS
  VALIDEE
  REJETEE
}

enum TypeDocument {
  CIN
  PASSEPORT
  CONTRAT
  PROCURATION
}

enum StatutDocument {
  DEPOSE
  CONFORME
  NON_CONFORME
}

model Demande {
  id     String @id @default(uuid())
  numero String @unique

  nomDemandeur    String
  prenomDemandeur String
  cin             String
  telephone       String
  email           String?

  referenceFonciere String
  adresseBien       String

  statut       StatutDemande @default(EN_ATTENTE)
  observations String?
  motifRejet   String?

  journalClotureId String?
  journalCloture   JournalCloture? @relation(fields: [journalClotureId], references: [id])

  utilisateurId String
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id])

  historiqueStatuts   HistoriqueStatutDemande[]
  documentsTeleverses DemandeDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cin, referenceFonciere])
  @@index([journalClotureId])
}

model HistoriqueStatutDemande {
  id            String        @id @default(uuid())
  ancienStatut  StatutDemande
  nouveauStatut StatutDemande
  motif         String?

  demandeId String
  demande   Demande @relation(fields: [demandeId], references: [id], onDelete: Cascade)

  utilisateurId String
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id])
  createdAt     DateTime    @default(now())

  @@index([demandeId])
  @@index([utilisateurId])
}

model DemandeDocument {
  id String @id @default(uuid())

  type TypeDocument

  nomOriginal   String
  nomStockage   String @unique
  cheminFichier String
  mimeType      String
  taille        Int

  statut             StatutDocument @default(DEPOSE)
  motifNonConformite String?

  demandeId String
  demande   Demande @relation(fields: [demandeId], references: [id], onDelete: Cascade)

  utilisateurId String
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([demandeId, type])
  @@index([demandeId])
  @@index([utilisateurId])
}

model JournalCloture {
  id     String @id @default(uuid())
  numero String @unique

  dateJour    DateTime @unique @db.Date
  dateCloture DateTime @default(now())

  observations String?

  responsableId String
  responsable   Utilisateur @relation(fields: [responsableId], references: [id])

  demandes Demande[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([responsableId])
}
